{
  "name": "RegionalApp",
  "version": "1.0.0",
  "private": true,
  "description": "MBB Regional Mobile App - React Native",
  "scripts": {
    "start": "react-native start",
    "test": "jest --ci --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "build:ios:debug:sit:development": "react-native run-ios --scheme RegionalApp-Dev --configuration Debug",
    "build:ios:release:staging:adhoc": "react-native run-ios --scheme RegionalApp-Staging --configuration Release",
    "build:ios:release:staging:appstore": "react-native run-ios --scheme RegionalApp --configuration Release",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.74.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^7.8.4",
    "react-native-safe-area-context": "^4.10.1",
    "react-native-screens": "^3.31.1",
    "react-redux": "^9.1.2",
    "redux": "^5.0.1",
    "@reduxjs/toolkit": "^2.2.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.6",
    "@babel/preset-env": "^7.24.6",
    "@babel/runtime": "^7.24.6",
    "@react-native/babel-preset": "^0.74.84",
    "@react-native/eslint-config": "^0.74.84",
    "@react-native/metro-config": "^0.74.84",
    "@react-native/typescript-config": "^0.74.84",
    "@testing-library/react-native": "^12.5.1",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "react-test-renderer": "18.2.0"
  },
  "jest": {
    "preset": "react-native",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-redux|@reduxjs/toolkit|immer)/)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ]
  }
}
